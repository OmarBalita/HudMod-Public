[sub_resource type="GDScript" id="GDScript_5jfbs"]
script/source = "extends Node

@onready var viewport_a: SubViewport = %SubViewport
@onready var quad_a: Sprite2D = %Sprite2D

@onready var viewport_b: SubViewport = %SubViewport2
@onready var quad_b: Sprite2D = %Sprite2D2

@onready var target_rect: ColorRect = $TargetRect
@onready var target_texture_rect: TextureRect = %TargetTextureRect

@export var source_texture: Texture2D
@export var effects: Array[ShaderMaterial] = []

func _process(delta: float) -> void:
	if Input.is_action_just_pressed(\"enter\"):
		process_passes(source_texture)

func process_passes(input: Texture2D) -> void:
	target_rect.hide()
	
	viewport_a.size = input.get_size()
	viewport_b.size = input.get_size()
	
	var read_vp: SubViewport = viewport_a
	var write_vp: SubViewport = viewport_b
	var read_quad: Sprite2D = quad_a
	var write_quad: Sprite2D = quad_b
	
	read_quad.texture = input
	
	for index: int in effects.size():
		var effect: ShaderMaterial = effects[index]
		
		var current_tex: ViewportTexture = read_vp.get_texture()
		write_quad.texture = current_tex
		write_quad.material = effect
		
		write_vp.render_target_update_mode = SubViewport.UPDATE_ONCE
		
		var temp_vp: SubViewport = read_vp
		var temp_quad: Sprite2D = read_quad
		read_vp = write_vp
		write_vp = temp_vp
		read_quad = write_quad
		write_quad = temp_quad
		
		await RenderingServer.frame_post_draw
	
	push_result(read_vp.get_texture())

func push_result(texture: Texture2D) -> void:
	target_rect.show()
	target_texture_rect.texture = texture

"

[sub_resource type="Shader" id="Shader_3c2gf"]
code = "shader_type canvas_item;

uniform int radius : hint_range(0, 10) = 3;

void fragment() {
	vec2 tex_size = vec2(textureSize(TEXTURE, 0));
	vec2 uv = UV;
	
	vec3 mean[4];
	vec3 std_dev[4];
	for (int i = 0; i < 4; i++) {
		mean[i] = vec3(.0);
		std_dev[i] = vec3(.0);
	}
	
	int n = (radius + 1) * (radius + 1);
	float f_n = float(n);
	
	int bounds[16] = int[](
		-radius, 0, -radius, 0,
		0, radius, -radius, 0,
		-radius, 0, 0, radius,
		0, radius, 0, radius
	);
	
	for (int i = 0; i < 4; i++) {
		for (int x = bounds[i*4]; x <= bounds[i*4+1]; x++) {
			for (int y = bounds[i*4+2]; y <= bounds[i*4+3]; y++) {
				vec3 c = texture(TEXTURE, uv + vec2(float(x), float(y)) / tex_size).rgb;
				mean[i] += c;
				std_dev[i] += c * c;
			}
		}
	}
	
	float min_sigma2 = 1e+2;
	vec3 final_color = vec3(.0);
	
	for (int i = 0; i < 4; i++) {
		mean[i] /= f_n;
		std_dev[i] = abs(std_dev[i] / f_n - mean[i] * mean[i]);
		float sigma2 = std_dev[i].r + std_dev[i].g + std_dev[i].b;
		
		if (sigma2 < min_sigma2) {
			min_sigma2 = sigma2;
			final_color = mean[i];
		}
	}
	
	COLOR.rgb = final_color;
}"

