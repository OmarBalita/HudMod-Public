shader_parameter/force = 0.2
shader_parameter/zoom = 1.0

[sub_resource type="Shader" id="Shader_jwv0l"]
code = "shader_type canvas_item;

uniform float size = 16.;
const float ratio = 1.142857142;

void fragment() {
	vec2 norm_size = vec2(size * ratio, size) * TEXTURE_PIXEL_SIZE;
	bool less_than_half = mod(UV.y / 2., norm_size.y) / norm_size.y < .5;
	vec2 uv = UV + vec2(norm_size.x * .5 * float(less_than_half), .0);
	vec2 center_uv = floor(uv / norm_size) * norm_size;
	vec2 norm_uv = mod(uv, norm_size) / norm_size;
	center_uv += mix(vec2(.0, .0),
		mix(mix(vec2(norm_size.x, -norm_size.y),
			vec2(.0, -norm_size.y),
			float(norm_uv.x < .5)),
			mix(vec2(.0, -norm_size.y),
			vec2(-norm_size.x, -norm_size.y),
			float(norm_uv.x < .5)),
			float(less_than_half)),
		float(norm_uv.y < .3333333) * float(norm_uv.y / .3333333 < (abs(norm_uv.x - .5) * 2.)));
	
	COLOR = textureLod(TEXTURE, center_uv, .0);
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_l0tnx"]
shader = SubResource("Shader_jwv0l")
shader_parameter/size = 20.0

[sub_resource type="Shader" id="Shader_gduh5"]
code = "shader_type canvas_item;

#include \"res://Build/Shader/Global.gdshaderinc\"

uniform vec2 light_dir = vec2(1., .0);
uniform float intensity: hint_range(.0, .02) = .005;
uniform vec4 highlight_color: source_color = vec4(1., 1., 1., 1.);
uniform vec4 shadow_color: source_color = vec4(.0, .0, .0, 1.);

void fragment() {
	vec4 color = texture(TEXTURE, UV);
	
	vec2 dir = normalize(light_dir) * intensity;
	
	float sample_plus = get_luminance(texture(TEXTURE, UV + dir).rgb);
	float sample_minus = get_luminance(texture(TEXTURE, UV - dir).rgb);
	
	float diff = sample_plus - sample_minus;
	
	vec4 base = color;
	vec4 final = base;
	
	if (diff > .0) {
		final = mix(final, highlight_color, clamp(diff * 5., .0, 1.));
	} else {
		final = mix(final, shadow_color, clamp(abs(diff) * 5., .0, 1.));
	}
	
	COLOR = final;
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_c0083"]
shader = SubResource("Shader_gduh5")
shader_parameter/light_dir = Vector2(1, 0)
shader_parameter/intensity = 0.005
shader_parameter/highlight_color = Color(1, 1, 1, 1)
shader_parameter/shadow_color = Color(0, 0, 0, 1)

