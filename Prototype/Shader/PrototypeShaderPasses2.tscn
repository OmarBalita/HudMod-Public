[sub_resource type="GDScript" id="GDScript_dvoev"]
script/source = "extends Node

@export var input_as_texture: Texture2D
@export var shader_materials: Array[ShaderMaterial]

@onready var ping_pong_renderer: PingPongRenderer = %PingPongRenderer
@onready var target_rect: TextureRect = %TargetRect

func _ready() -> void:
	var texture: ViewportTexture = await ping_pong_renderer.request_process_output(input_as_texture, Vector2.ONE, shader_materials)
	target_rect.texture = texture
"

[sub_resource type="Shader" id="Shader_3c2gf"]
code = "shader_type canvas_item;

uniform int radius : hint_range(0, 10) = 3;

void fragment() {
	vec2 tex_size = vec2(textureSize(TEXTURE, 0));
	vec2 uv = UV;
	
	vec3 mean[4];
	vec3 std_dev[4];
	for (int i = 0; i < 4; i++) {
		mean[i] = vec3(.0);
		std_dev[i] = vec3(.0);
	}
	
	int n = (radius + 1) * (radius + 1);
	float f_n = float(n);
	
	int bounds[16] = int[](
		-radius, 0, -radius, 0,
		0, radius, -radius, 0,
		-radius, 0, 0, radius,
		0, radius, 0, radius
	);
	
	for (int i = 0; i < 4; i++) {
		for (int x = bounds[i*4]; x <= bounds[i*4+1]; x++) {
			for (int y = bounds[i*4+2]; y <= bounds[i*4+3]; y++) {
				vec3 c = texture(TEXTURE, uv + vec2(float(x), float(y)) / tex_size).rgb;
				mean[i] += c;
				std_dev[i] += c * c;
			}
		}
	}
	
	float min_sigma2 = 1e+2;
	vec3 final_color = vec3(.0);
	
	for (int i = 0; i < 4; i++) {
		mean[i] /= f_n;
		std_dev[i] = abs(std_dev[i] / f_n - mean[i] * mean[i]);
		float sigma2 = std_dev[i].r + std_dev[i].g + std_dev[i].b;
		
		if (sigma2 < min_sigma2) {
			min_sigma2 = sigma2;
			final_color = mean[i];
		}
	}
	
	COLOR.rgb = final_color;
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_dqyh3"]
shader = SubResource("Shader_3c2gf")
shader_parameter/radius = 10

[sub_resource type="Shader" id="Shader_rdepk"]
code = "shader_type canvas_item;

#include \"res://Build/Shader/Global.gdshaderinc\"

uniform vec2 dir = vec2(1., .0);
uniform float power = .05;
uniform int quality: hint_range(1, 64) = 4;
uniform bool clip_border = false;
uniform bool transparancy = true;

void vertex(){
	if (clip_border == false) {
		vec2 blur_size = abs(normalize(dir) * power) * 2.;
		VERTEX *= blur_size + 1.;
		UV = (UV - .5) * (blur_size + 1.) + .5;
	}
}

void fragment(){
	float in_square = inside_unit_square(UV);
	float num_samples = in_square;
	
	vec4 color = texture(TEXTURE, UV) * in_square;
	vec2 step_size = normalize(dir) * power / (float(quality));
	vec2 uv;
	
	for(int i = 1; i <= quality; i++){
		vec2 uv_scalar = step_size * float(i);
		
		uv = UV + uv_scalar;
		in_square = inside_unit_square(uv);
		num_samples += in_square;
		color += texture(TEXTURE, uv) * in_square;
		
		uv = UV - uv_scalar;
		in_square = inside_unit_square(uv);
		num_samples += in_square;
		color += texture(TEXTURE, uv) * in_square;
	}
	
	color.rgb /= num_samples;
	if (transparancy) {
		color.a /= float(quality) * 2.0 + 1.0;
	}
	
	COLOR = color;
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_0slx0"]
shader = SubResource("Shader_rdepk")
shader_parameter/dir = Vector2(1, 0)
shader_parameter/power = 0.05
shader_parameter/quality = 8
shader_parameter/clip_border = false
shader_parameter/transparancy = true

[sub_resource type="Shader" id="Shader_4vwar"]
code = "shader_type canvas_item;

uniform float force: hint_range(-.3, 5.) = .2;
uniform float zoom: hint_range(-2., 2.) = 1.;

void fragment() {
	vec2 p = UV * 2. - 1.;
	float r2 = dot(p, p);
	float f = 1. + force * r2;
	p *= f / (1. + force * zoom);
	vec2 final_uv = (p + 1.) / 2.;
	vec4 color = texture(TEXTURE, final_uv);
	if (final_uv.x < .0 || final_uv.x > 1. || final_uv.y < .0 || final_uv.y > 1.) {
		color = vec4(.0, .0, .0, 1.);
	}
	COLOR = color;
}"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_7o1x4"]
