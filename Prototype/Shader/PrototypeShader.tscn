[sub_resource type="Shader" id="Shader_rlbq7"]
code = "shader_type canvas_item;

#include \"res://Build/Shader/Global.gdshaderinc\"

uniform float time;

uniform float intensity: hint_range(.0, 1.) = .3;
uniform float grain_size: hint_range(1., 20.) = 3.;
uniform bool monochrome = true;

void fragment() {
	vec4 color = texture(TEXTURE, UV);
	
	vec2 grain_uv = floor(UV / (TEXTURE_PIXEL_SIZE * grain_size)) * (TEXTURE_PIXEL_SIZE * grain_size);
	
	float luminance = get_luminance(color.rgb);
	float mask = pow(luminance, .5) * (1. - luminance);
	
	vec3 noise_output;
	if (monochrome) {
		float noise = random(grain_uv + fract(time));
		noise_output = vec3(noise);
	} else {
		noise_output = vec3(
			random(grain_uv + fract(time + .1)),
			random(grain_uv + fract(time + .2)),
			random(grain_uv + fract(time + .3))
		);
	}
	
	color.rgb += (noise_output - .5) * intensity * (mask * 4.);
	
	COLOR = color;
}"

