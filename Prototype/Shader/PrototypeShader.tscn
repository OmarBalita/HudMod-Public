[sub_resource type="Shader" id="Shader_vfnuj"]
code = "shader_type canvas_item;

uniform float exposure: hint_range(-5., 5.) = .0;
uniform float contrast: hint_range(.0, 3.) = 1.;
uniform float offset: hint_range(.0, 1.) = .5;
uniform float highlights: hint_range(-1., 1.) = .0;
uniform float shadows: hint_range(-1., 1.) = .0;
uniform float whites: hint_range(-1., 1.) = .0;
uniform float blacks: hint_range(-1., 1.) = .0;

void fragment() {
	vec4 tex = texture(TEXTURE, UV);
	vec3 color = tex.rgb;
	
	// Exposure
	color *= pow(2., exposure);
	
	// Contrast
	color = (color - offset) * contrast + offset;
	
	float luma = dot(color, vec3(.2126, .7152, .0722));
	
	// Highlights
	float high_mask = smoothstep(.5, 1., luma);
	color += high_mask * highlights;
	
	// Shadows
	float shadow_mask = 1.0 - high_mask;
	color += shadow_mask * shadows;
	
	// Whites
	float white_mask = smoothstep(0.8, 1.0, luma);
	color += white_mask * whites;
	
	// Blacks
	float black_mask = 1.0 - smoothstep(0.0, 0.2, luma);
	color += black_mask * blacks;
	
	COLOR = mix(tex, vec4(color, tex.a), 1.);
	COLOR.rgb = mix(tex.rgb, color.rgb, 1.);
}

"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_dcitl"]
