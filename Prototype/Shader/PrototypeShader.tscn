shader_parameter/whites = 0.0
shader_parameter/blacks = 0.0

[sub_resource type="Shader" id="Shader_ehi37"]
code = "shader_type canvas_item;

uniform vec3 lift : source_color = vec3(0.0);
uniform vec3 gamma : source_color = vec3(1.0);
uniform vec3 gain : source_color = vec3(1.0);
uniform float offset = .0;

void fragment() {
	vec4 tex = texture(TEXTURE, UV);
	vec3 color = tex.rgb;
	
	vec3 result = pow(max(vec3(.0), color * gain + lift + offset), 1. / gamma);
	
	COLOR.rgb = result;
}

"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_inflt"]
