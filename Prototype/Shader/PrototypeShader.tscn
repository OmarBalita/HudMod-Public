[sub_resource type="Shader" id="Shader_0qjtk"]
code = "shader_type canvas_item;

uniform float aspect_ratio: hint_range(-1., 1.) = .2; 
uniform float smoothness: hint_range(.0, 1.) = .0;
uniform float curve_strength: hint_range(-5., 5.) = .0;
uniform float rotation_degrees = .0;
uniform vec4 bars_color: source_color = vec4(.0, .0, .0, 1.);

void fragment() {
	float angle = radians(rotation_degrees);
	vec2 uv = UV - .5;
	float cos_a = cos(angle);
	float sin_a = sin(angle);
	mat2 rotation_matrix = mat2(vec2(cos_a, -sin_a), vec2(sin_a, cos_a));
	uv = rotation_matrix * uv + .5;
	vec4 color = texture(TEXTURE, UV);
	float x_dist = abs(uv.x - .5);
	float offset = pow(x_dist, 2.) * curve_strength;
	float low = (aspect_ratio * .5) + offset;
	float high = 1. - low;
	float mask = smoothstep(low, low + smoothness, uv.y) * (1. - smoothstep(high - smoothness, high, uv.y));
	color.rgb = mix(bars_color.rgb, color.rgb, mask);
	COLOR = color;
}

"

