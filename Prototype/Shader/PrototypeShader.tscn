[sub_resource type="Shader" id="Shader_iov73"]
code = "shader_type canvas_item;

uniform bool invert_red = true;
uniform bool invert_green = true;
uniform bool invert_blue = true;
uniform bool invert_alpha;

void fragment() {
	if (invert_red) COLOR.r = 1. - COLOR.r;
	if (invert_green) COLOR.g = 1. - COLOR.g;
	if (invert_blue) COLOR.b = 1. - COLOR.b;
	if (invert_alpha) COLOR.a = 1. - COLOR.a;
}
"

