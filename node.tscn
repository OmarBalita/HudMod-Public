[sub_resource type="GDScript" id="GDScript_nxiqb"]
script/source = "extends Node

const VERCEL_URL: String = \"https://hud-mod-api.vercel.app/api/supporters\"

func _ready() -> void:
	fetch_patrons()

func fetch_patrons() -> void:
	var http_request:= HTTPRequest.new()
	add_child(http_request)
	http_request.request_completed.connect(_on_request_completed)
	var error: Error = http_request.request(VERCEL_URL)

func _on_request_completed(result: int, response_code: int, headers: PackedStringArray, body: PackedByteArray) -> void:
	if response_code == 200:
		var json: JSON = JSON.new()
		var parse_result: Error = json.parse(body.get_string_from_utf8())
		
		if parse_result == OK:
			var response: Dictionary = json.get_data()
"

[node name="Node" type="Node" unique_id=1265524575]
script = SubResource("GDScript_nxiqb")
