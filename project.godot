; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="HudMod"
run/main_scene="uid://ckmqu1nrqmxml"
config/features=PackedStringArray("4.4", "Forward Plus")
boot_splash/bg_color=Color(0, 0, 0, 1)
boot_splash/show_image=false
config/icon="uid://daw7g1bq36r4n"

[autoload]

TypeServer="*res://Autoload/TypeServer.gd"
ObjectServer="*res://Autoload/ObjectServer.gd"
TimeServer="*res://Autoload/TimeServer.gd"
IS="*res://Autoload/InterfaceServer.gd"
WindowManager="*res://Autoload/WindowManager.gd"
MediaServer="*res://Autoload/MediaServer.gd"
EditorServer="*res://Autoload/EditorServer.gd"
ProjectServer="*res://Autoload/ProjectServer.gd"
Scene2="*res://Autoload/Scene2.gd"
MediaCache="*res://Autoload/MediaCache.gd"

[display]

window/size/viewport_width=1700
window/size/viewport_height=800
window/subwindows/embed_subwindows=false
window/icon="uid://yb10nyikmf4a"

[dotnet]

project/assembly_name="Edit App"

[editor_plugins]

enabled=PackedStringArray("res://addons/gde_gozen/plugin.cfg")

[file_customization]

folder_colors={
"res://Autoload/": "yellow",
"res://Build/": "gray",
"res://Editor/": "teal",
"res://Prototype/": "purple",
"res://UI&UX/": "pink"
}

[global_group]

media_explorer=""
time_line=""
player=""
properties=""
guide_label=""
notification_label=""
clip_nodes_explorer=""
drawable_rect=""

[input]

test={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":84,"key_label":0,"unicode":116,"location":0,"echo":false,"script":null)
]
}
left_button={
"deadzone": 0.2,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":1,"position":Vector2(205, 11),"global_position":Vector2(214, 59),"factor":1.0,"button_index":1,"canceled":false,"pressed":true,"double_click":false,"script":null)
]
}
snap={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194326,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
